{
  "expo": {
    "name": "Arena Score",
    "slug": "copa2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./src/assets/LOGO DQ.png",
    "splash": {
      "image": "./src/assets/LOGO DQ.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.copa2026.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/LOGO DQ.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.copa2026.app",
      "softwareKeyboardLayoutMode": "pan",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "navigationBar": {
        "backgroundColor": "#0A0E1A",
        "barStyle": "light-content"
      }
    },
    "web": {
      "bundler": "webpack",
      "favicon": "./src/assets/LOGO DQ.png",
      "name": "Arena Score",
      "shortName": "Arena Score",
      "description": "Acompanhe a Copa do Mundo FIFA 2026 em tempo real — jogos ao vivo, grupos, palpites e artilheiros",
      "backgroundColor": "#0A0E1A",
      "themeColor": "#00A550",
      "lang": "pt-BR",
      "preferRelatedApplications": false,
      "meta": {
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "black-translucent",
        "apple-mobile-web-app-title": "Arena Score"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/LOGO DQ.png",
          "color": "#0A0E1A",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "22b58112-369d-4cd4-866b-8999758b4f13"
      }
    },
    "owner": "dholand4"
  }
}
